    {
      "parameters": {
        "jsCode": "const include = [\"software engineer\", \"backend\", \"full stack\", \"new grad\", \"university graduate\"];\nconst exclude = [\"senior\", \"staff\", \"principal\", \"manager\", \"director\", \"lead\"];\n\nreturn items.filter(item => {\n  const title = (item.json.title || \"\").toLowerCase();\n  const location = (item.json.location || \"\").toLowerCase();\n\n  const hasInclude = include.some(word => title.includes(word));\n  const hasExclude = exclude.some(word => title.includes(word));\n\n  const isUS = location.includes(\"united states\") || location.includes(\"us\") || location.includes(\"remote\");\n\n  return hasInclude && !hasExclude && isUS;\n});"
      },
