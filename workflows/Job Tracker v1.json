        "jsCode": "const jobs = $json.jobs || [];\n\nreturn jobs.map(job => {\n  return {\n    json: {\n      company: \"Stripe\",\n      title: job.title,\n      location: job.location?.name || \"\",\n      url: job.absolute_url\n    }\n  };\n});"
